# 项目根目录 .gitignore 文件

# 后端 Python 项目
# 编译产物
__pycache__/
*.pyc

# 日志文件
logs/
backend/logs/

# 环境变量文件
.env
# 安装的依赖
.pip/
venv/
env/

# 临时文件
tempCodeRunnerFile.py

# 测试文件
*.test.py

# 前端项目（前端已有自己的 .gitignore）
# 但如果需要，也可以在这里添加

# IDE 相关
.idea/
.vscode/
*.swp
*.swo
*~

# 操作系统相关
.DS_Store
Thumbs.db

# 构建产物
dist/
build/

# 包管理
node_modules/
.npm/

# 其他
.env.local
.env.development.local
.env.test.local
.env.production.local