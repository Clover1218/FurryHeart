    "type": "insight",
    "tags": ["用户", "晚上", "空虚", "关心"],
    "emotion": "sadness",
    "emotion_intensity": 0.7,
    "importance": 0.8,
    "emotion_confidence": 0.85,
    "triples": [
      {
        "subject": "用户",
        "predicate": "感到",
        "object": "空虚"
      },
      {
        "subject": "用户",
        "predicate": "觉得缺少",
        "object": "关心"
      }
    ]
  }
]

